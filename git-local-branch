#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$ROOT_DIR/lib/common.sh"

main() {
  require_command git
  require_command fzf

  if [[ "$#" -gt 1 ]]; then
    usage_error "git local-branch [branch-pattern]"
  fi

  local pattern="${1:-}"
  local candidates
  candidates="$(git_list_local_branches "$pattern")"

  if [[ -z "$candidates" ]]; then
    die "no local branches matched"
  fi

  local selected
  if ! selected="$(printf '%s\n' "$candidates" | fzf)"; then
    die "branch selection was canceled"
  fi
  [[ -n "$selected" ]] || die "branch selection was canceled"

  git switch "$selected" >/dev/null || die "failed to switch to '$selected'"
}

main "$@"

